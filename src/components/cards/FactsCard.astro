---
import BentoCard from "../BentoCard.astro";
import FactsCardContent from "../FactsCardContent.svelte";

let facts: string[] | null = null;

try {
    const response = await fetch(
        "https://statistician.bensoyka.com/public/facts",
    );

    if (response.ok) {
        const data = await response.json();
        facts = data.facts;
    } else {
        console.warn("Failed to fetch facts: non-OK response.");
    }
} catch (e) {
    console.warn("Failed to fetch facts:", e);
}
---

<BentoCard title="Fun facts" colSpan="lg:col-span-2">
    <FactsCardContent client:load {facts} />
</BentoCard>

<script>
    import { animate } from "motion";

    const onPageLoad = () => {
        const cardsContainer = document.querySelector("#facts");
        if (cardsContainer) {
            const cards = Array.from(cardsContainer.children);
            cards.forEach((card, index) => {
                animate(
                    card,
                    {
                        opacity: [0, 1],
                        transform: ["translateX(40px)", "translateX(0)"],
                    },
                    {
                        duration: 0.5,
                        delay: 0.9 + index * 0.1,
                    },
                );
            });
        }
    };

    if (typeof window !== "undefined") {
        window.addEventListener("load", onPageLoad);
    }
</script>
